# Brewfile - Homebrew dependencies
# Install with: brew bundle --file=~/.dotfiles/brew/.Brewfile

# Taps
tap "homebrew/bundle"
tap "homebrew/services"

# Core CLI tools
brew "git"
brew "wget"
brew "curl"
brew "jq"
brew "ripgrep"
brew "fd"
brew "bat"
brew "fzf"

# Development tools
brew "gh"              # GitHub CLI
brew "mise"            # Version manager (alternative to asdf)
brew "gnu-tar"

# Optional: Uncomment tools you want
# brew "docker"
# brew "docker-compose"
# brew "terraform"
# brew "awscli"
# brew "node"
# brew "python"
# brew "go"

# Applications (casks)
# cask "visual-studio-code"
# cask "docker"
# cask "iterm2"
