#!/usr/bin/env python3
"""
Remove mcpServers from ~/.claude.json so that settings.json
(managed via dotfiles) is the single source of truth.
"""
import json
import os
import shutil
from datetime import datetime

path = os.path.expanduser("~/.claude.json")
backup = f"{path}.bak-{datetime.now().strftime('%Y%m%d-%H%M%S')}"

with open(path) as f:
    data = json.load(f)

# Remove top-level mcpServers
removed_top = data.pop("mcpServers", None)

# Remove per-project mcpServers
removed_projects = []
for proj, cfg in data.get("projects", {}).items():
    if cfg.get("mcpServers"):
        cfg.pop("mcpServers")
        removed_projects.append(proj)

if removed_top is None and not removed_projects:
    print("Nothing to clean — no mcpServers found in ~/.claude.json")
else:
    shutil.copy(path, backup)
    with open(path, "w") as f:
        json.dump(data, f, indent=2)
    if removed_top is not None:
        print(f"Removed top-level mcpServers: {list(removed_top.keys())}")
    if removed_projects:
        print(f"Cleared mcpServers from {len(removed_projects)} project(s)")
    print(f"Backup saved to {backup}")
