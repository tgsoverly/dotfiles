#!/usr/bin/env bash
# Bootstrap script for dotfiles installation

set -e

DOTFILES_DIR="${HOME}/.dotfiles"
BACKUP_DIR="${HOME}/.dotfiles-backup-$(date +%Y%m%d-%H%M%S)"

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

log_info() {
  echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
  echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
  echo -e "${RED}[ERROR]${NC} $1"
}

# Check if running from the dotfiles directory
if [ ! -f "$(pwd)/.zshrc" ]; then
  log_error "Please run this script from your dotfiles directory"
  exit 1
fi

log_info "Installing dotfiles..."

# Create backup directory
mkdir -p "$BACKUP_DIR"
log_info "Backup directory: $BACKUP_DIR"

# Function to symlink a file
symlink_file() {
  local source="$1"
  local target="$2"

  # If target exists and is not a symlink, back it up
  if [ -e "$target" ] && [ ! -L "$target" ]; then
    log_warn "Backing up existing $target"
    mv "$target" "$BACKUP_DIR/"
  fi

  # Remove existing symlink if it exists
  if [ -L "$target" ]; then
    rm "$target"
  fi

  # Create symlink
  ln -s "$source" "$target"
  log_info "Linked: $target -> $source"
}

# Create ~/.dotfiles symlink if it doesn't exist
if [ ! -L "$DOTFILES_DIR" ] && [ "$(pwd)" != "$DOTFILES_DIR" ]; then
  if [ -e "$DOTFILES_DIR" ]; then
    log_warn "Backing up existing $DOTFILES_DIR"
    mv "$DOTFILES_DIR" "$BACKUP_DIR/"
  fi
  ln -s "$(pwd)" "$DOTFILES_DIR"
  log_info "Created $DOTFILES_DIR symlink"
fi

# Symlink .zshrc
symlink_file "${DOTFILES_DIR}/.zshrc" "${HOME}/.zshrc"

# Symlink gitconfig
if [ -f "${DOTFILES_DIR}/git/.gitconfig" ]; then
  symlink_file "${DOTFILES_DIR}/git/.gitconfig" "${HOME}/.gitconfig"
elif [ -f "${DOTFILES_DIR}/gitconfig" ]; then
  symlink_file "${DOTFILES_DIR}/gitconfig" "${HOME}/.gitconfig"
fi

# Symlink Claude Code settings
if [ -f "${DOTFILES_DIR}/ai/claude-code/settings.json" ]; then
  mkdir -p "${HOME}/.claude"
  symlink_file "${DOTFILES_DIR}/ai/claude-code/settings.json" "${HOME}/.claude/settings.json"
  # Remove any mcpServers from ~/.claude.json to avoid conflicts with settings.json
  if [ -f "${HOME}/.claude.json" ]; then
    log_info "Cleaning mcpServers from ~/.claude.json..."
    python3 "${DOTFILES_DIR}/scripts/bin/claude-mcp-clean"
  fi
fi

# Make scripts executable
if [ -d "${DOTFILES_DIR}/scripts/bin" ]; then
  log_info "Making scripts executable..."
  chmod +x "${DOTFILES_DIR}/scripts/bin"/*
fi

log_info ""
log_info "✅ Dotfiles installation complete!"
log_info ""
log_info "Next steps:"
log_info "  1. Restart your terminal or run: source ~/.zshrc"
log_info "  2. Review and customize files in ${DOTFILES_DIR}/zsh/"
log_info "  3. Add local customizations to ~/.zshrc.local (not version controlled)"
log_info ""
log_info "Backups saved to: $BACKUP_DIR"
